FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY netease-api-new/package*.json ./

# Install dependencies
RUN npm config set registry https://registry.npmmirror.com && npm install --production

# Copy application files
COPY netease-api-new/ .

# Create required token file
RUN mkdir -p /tmp && echo '' > /tmp/anonymous_token

EXPOSE 3000

CMD ["node", "app.js"]